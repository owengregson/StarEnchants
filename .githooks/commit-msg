#!/bin/sh
# StarEnchants — enforce Conventional Commits on the subject line.

msg_file="$1"
first_line=$(head -n1 "$msg_file")

# Allow machine-generated merge/revert/fixup subjects.
case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .{1,}'

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

echo "✗ Commit message must follow Conventional Commits:" >&2
echo "    <type>(<optional-scope>)?: <subject>" >&2
echo "  types: feat fix docs style refactor perf test build ci chore revert" >&2
echo "  e.g.:  feat(effects): add POTION effect handler" >&2
echo "  got:   $first_line" >&2
exit 1
